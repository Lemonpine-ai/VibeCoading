# ─────────────────────────────────────────────────────────
# Supabase — Project Settings → API 에서 복사
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 (클라이언트에 절대 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────
# WebRTC TURN 서버 설정
#
# 세 항목이 모두 있어야 RTCPeerConnection ICE 목록에 TURN이 추가됩니다.
# 하나라도 빠지면 STUN만 사용되어 대칭 NAT/LTE 환경에서 연결 실패 가능.
#
# 권장 방식 — WEBRTC_TURN_* (서버 전용, NEXT_PUBLIC_ 없음)
#   /api/webrtc/ice-config 가 런타임에 읽으므로,
#   Vercel 환경변수만 바꾸고 재배포하면 재빌드 없이 반영됩니다.
#
# 대안 — NEXT_PUBLIC_WEBRTC_TURN_* (클라이언트 번들에 인라인)
#   값을 바꾼 뒤 반드시 재빌드·재배포 필요.
# ─────────────────────────────────────────────────────────

# [권장] 서버 전용 환경변수
WEBRTC_TURN_URLS=turn:your-server.com:3478
WEBRTC_TURN_USERNAME=your-username
WEBRTC_TURN_CREDENTIAL=your-password

# 여러 URL을 쉼표로 구분하면 UDP/TCP/TLS를 한 번에 등록할 수 있습니다.
# 예: UDP가 막힌 환경(공용 Wi-Fi, 일부 LTE) 대응을 위한 3종 세트
# WEBRTC_TURN_URLS=turn:your-server.com:3478,turn:your-server.com:443?transport=tcp,turns:your-server.com:443?transport=tcp

# [대안] 클라이언트 번들 인라인 (재빌드 필요)
# NEXT_PUBLIC_WEBRTC_TURN_URLS=turn:your-server.com:3478
# NEXT_PUBLIC_WEBRTC_TURN_USERNAME=your-username
# NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=your-password

# ─────────────────────────────────────────────────────────
# TURN URL 올바른 형식
#   ✅ turn:your-server.com:3478
#   ✅ turn:your-server.com:443?transport=tcp
#   ✅ turns:your-server.com:443?transport=tcp
#   ❌ turn:https://your-server.com:3478  ← https:// 포함하면 브라우저가 인식 못 함
# ─────────────────────────────────────────────────────────
