{
  "name": "voimeow-chatbot",
  "version": "1.0.0",
  "description": "VoiMeow 챗봇 - OpenAI API를 활용한 고객센터 챗봇",
  "type": "module",
  "scripts": {
    "postinstall": "playwright install chromium",
    "setup": "npm install && playwright install chromium",
    "dev": "vite",
    "dev:dashboard": "vite --open /figma-mcp-dashboard/index.html",
    "build": "vite build",
    "preview": "vite preview",
    "mcp:playwright": "npx -y @playwright/mcp@latest",
    "mcp:figma": "npx -y cursor-talk-to-figma-mcp@latest",
    "mcp:socket": "npx -y cursor-talk-to-figma-socket",
    "browsers:install": "playwright install chromium",
    "mcp:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-mcp-prerequisites.ps1",
    "git:enable-auto-push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-git-hooks.ps1",
    "prepare": "husky"
  },
  "dependencies": {
    "openai": "^4.77.3"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.35",
    "husky": "^9.1.7",
    "playwright": "^1.49.1",
    "vite": "^5.4.11"
  }
}
